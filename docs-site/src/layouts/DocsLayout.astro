---
import "../styles/global.css"

interface Frontmatter {
  title: string
  description?: string
  lede?: string
}

interface Props extends Frontmatter {
  frontmatter?: Frontmatter
}

const props = Astro.props
const { title, description, lede } = props.frontmatter ?? props
const pageTitle = title === "Extreme InfiniTV docs" ? title : `${title} - Extreme InfiniTV docs`

const base = import.meta.env.BASE_URL.replace(/\/$/, "")

const navLinks = [
  { href: `${base}/`, label: "Docs" },
  { href: "https://github.com/infinitel8p/Extreme-InfiniTV", label: "GitHub", external: true },
  { href: "https://github.com/infinitel8p/Extreme-InfiniTV/releases/latest", label: "Download", external: true },
]

const sidebarGroups = [
  {
    title: "Start",
    links: [
      { href: `${base}/`, label: "Overview" },
      { href: `${base}/getting-started/`, label: "Getting started" },
    ],
  },
  {
    title: "Using the app",
    links: [
      { href: `${base}/playlists/`, label: "Playlists (Xtream + M3U)" },
      { href: `${base}/external-players/`, label: "External players" },
      { href: `${base}/keyboard-and-d-pad/`, label: "Keyboard + D-pad" },
      { href: `${base}/troubleshooting/`, label: "Troubleshooting" },
    ],
  },
  {
    title: "Contribute",
    links: [
      { href: `${base}/translations/`, label: "Translations" },
    ],
  },
]

const here = Astro.url.pathname.replace(/\/+$/, "") || "/"
function isCurrent(href: string) {
  const normalized = href.replace(/\/+$/, "") || "/"
  return normalized === here
}

const pathWithoutBase = here.startsWith(base) ? here.slice(base.length) || "/" : here
const editPath = pathWithoutBase === "/" ? "/index.astro" : `${pathWithoutBase}.md`
const editUrl = `https://github.com/infinitel8p/Extreme-InfiniTV/blob/main/docs-site/src/pages${editPath}`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={pageTitle} />
    {description && <meta property="og:description" content={description} />}
    <link rel="icon" type="image/png" href="https://raw.githubusercontent.com/infinitel8p/Extreme-InfiniTV/refs/heads/main/src-tauri/icons/32x32.png" />
  </head>
  <body>
    <header class="site-nav">
      <a class="brand" href={`${base}/`}>
        <span class="brand-mark" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="13" rx="2.5" />
            <path d="M8 21h8" />
            <path d="M12 18v3" />
          </svg>
        </span>
        Extreme InfiniTV docs
      </a>
      <span class="spacer"></span>
      <nav class="nav-links" aria-label="Site">
        {navLinks.map((link) => (
          <a href={link.href} {...(link.external ? { rel: "noopener", target: "_blank" } : {})}>
            {link.label}
          </a>
        ))}
      </nav>
      <button class="menu-btn" type="button" aria-controls="sidebar" aria-expanded="false" data-menu-toggle>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        Menu
      </button>
    </header>

    <div class="layout">
      <aside id="sidebar" class="sidebar" aria-label="Documentation">
        {sidebarGroups.map((group) => (
          <div class="sidebar-group">
            <p class="sidebar-group-title">{group.title}</p>
            <ul class="sidebar-list">
              {group.links.map((link) => (
                <li>
                  <a href={link.href} aria-current={isCurrent(link.href) ? "page" : undefined}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </aside>

      <main class="content">
        <h1>{title}</h1>
        {lede && <p class="lede">{lede}</p>}
        <slot />
        <footer class="page-footer">
          <span>Extreme InfiniTV - GPL-3.0-or-later</span>
          <span>
            <a href="https://github.com/infinitel8p/Extreme-InfiniTV/issues" rel="noopener" target="_blank">Report an issue</a>
            {" / "}
            <a href={editUrl} rel="noopener" target="_blank">Edit this page</a>
          </span>
        </footer>
      </main>
    </div>

    <script is:inline>
      (() => {
        const btn = document.querySelector("[data-menu-toggle]")
        const sidebar = document.getElementById("sidebar")
        if (!btn || !sidebar) return
        btn.addEventListener("click", () => {
          const isOpen = sidebar.getAttribute("data-open") === "true"
          sidebar.setAttribute("data-open", String(!isOpen))
          btn.setAttribute("aria-expanded", String(!isOpen))
        })
        document.addEventListener("click", (event) => {
          if (window.matchMedia("(min-width: 861px)").matches) return
          const target = event.target
          if (target instanceof Node && (sidebar.contains(target) || btn.contains(target))) return
          sidebar.setAttribute("data-open", "false")
          btn.setAttribute("aria-expanded", "false")
        })
      })()
    </script>
  </body>
</html>
